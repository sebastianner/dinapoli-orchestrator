{
  "name": "dinapoli-orchestrator",
  "version": "1.0.0",
  "description": "Dinapoli Pizza order orchestrator: WS order intake, persistent print queue, billing and payment.",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc && cp -r src/assets dist/assets",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "db:reset": "tsx src/db/migrate.ts --reset && tsx src/db/seed.ts",
    "ws:client": "tsx scripts/test-order-client.ts",
    "ws:simulate": "tsx scripts/simulate-orders.ts"
  },
  "dependencies": {
    "better-sqlite3": "^11.9.1",
    "express": "^4.21.2",
    "pngjs": "^7.0.0",
    "puppeteer": "^25.3.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.25",
    "@types/node": "^26.1.1",
    "@types/pngjs": "^6.0.5",
    "@types/ws": "^8.18.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  }
}
