erDiagram
  RESTAURANT_TABLES ||--o{ ORDERS : seats
  EMPLOYEES |o--o{ ORDERS : "placed by"

  CATEGORIES ||--o{ PRODUCTS : contains
  PRODUCTS ||--o{ PRODUCT_SIZES : "priced as"
  PRODUCTS ||--o{ PRODUCT_OPTIONS : "variant of"

  PIZZA_GROUPS ||--o{ PIZZA_GROUP_SIZES : prices
  PIZZA_SIZES ||--o{ PIZZA_GROUP_SIZES : "priced in"
  PIZZA_GROUPS ||--o{ PIZZA_GROUP_FLAVORS : offers
  PIZZA_FLAVORS ||--o{ PIZZA_GROUP_FLAVORS : "offered by"

  ORDERS ||--o{ ORDER_ITEMS : has
  ORDERS ||--o{ ORDER_PAYMENTS : "settled by"
  PRODUCTS ||--o{ ORDER_ITEMS : ordered_as
  PRODUCT_SIZES ||--o{ ORDER_ITEMS : sized_as
  PRODUCT_OPTIONS ||--o{ ORDER_ITEMS : chosen_as
  PIZZA_GROUPS ||--o{ ORDER_ITEMS : grouped_as
  PIZZA_SIZES ||--o{ ORDER_ITEMS : sized_as
  PIZZA_FLAVORS ||--o{ ORDER_ITEMS : "single flavor of"
  ORDER_ITEMS ||--o{ ORDER_ITEM_FLAVORS : includes
  PIZZA_FLAVORS ||--o{ ORDER_ITEM_FLAVORS : chosen_in
  ORDERS ||--o{ PRINT_JOBS : "printed as"

  CASH_FLOW ||--o{ CASH_EXPENSES : records

  RESTAURANT_TABLES {
    int id PK
    int number "1 to 9, unique"
    text status "free or busy, derived from open orders"
  }

  EMPLOYEES {
    int id PK
    text name
    text picture_url "nullable"
    int is_active "default 1. soft delete - false instead of removing the row"
  }

  CATEGORIES {
    int id PK
    text key "stable id, e.g. appetizers, drinks. not 'pizzas'"
    text name
  }
  PRODUCTS {
    int id PK
    int category_id FK
    text key "stable id within category, e.g. fancaccia"
    text name
    text description "nullable"
    int price "nullable. null when priced via PRODUCT_SIZES (e.g. calzone)"
    int is_available
    int requires_pizza_flavor "bool. true for gratin, calzone"
  }
  PRODUCT_SIZES {
    int id PK
    int product_id FK
    text key "e.g. small, large"
    text name
    int price
  }
  PRODUCT_OPTIONS {
    int id PK
    int product_id FK
    text key "stable id within product, e.g. coca_cola. no price impact"
    text name "e.g. Coca-Cola, Poker"
  }

  PIZZA_GROUPS {
    int id PK
    text key "classic or special"
    text name
  }
  PIZZA_SIZES {
    int id PK
    text key "slice, personal, small, medium, large, xlarge"
    text name
    int slices
    int max_flavors
  }
  PIZZA_GROUP_SIZES {
    int id PK
    int group_id FK
    int size_id FK
    int price "nullable. null for 'slice' in current menu data"
  }
  PIZZA_FLAVORS {
    int id PK
    text key
    text name
    text description "nullable"
    int extra_cost
    int is_available
  }
  PIZZA_GROUP_FLAVORS {
    int group_id PK, FK
    int flavor_id PK, FK
  }

  ORDERS {
    int id PK
    text order_type "dine_in, takeaway, delivery"
    text status "PENDING, PRINTING, ACTIVE, COMPLETED"
    int employee_id FK "nullable. who placed the order, if recorded"
    text payment_method "nullable. pre-declared intent; NULL again once settled by a mixed payment (see ORDER_PAYMENTS)"
    int table_number "nullable. dine_in only, 1 to 9"
    text customer_name "nullable. takeaway, delivery"
    text phone "nullable. delivery only"
    text address "nullable. delivery only"
    text notes "nullable. order-level comments"
    int total "sum of items only, excludes tip and delivery_fee"
    int tip "default 0. settable/updatable any time, excluded from total/sales totals"
    int delivery_fee "default 0. delivery orders only, included in invoice/sales totals (unlike tip)"
    text created_at
    text completed_at "nullable. set on COMPLETED"
    int print_attempts "recovery bookkeeping, default 0"
  }
  ORDER_ITEMS {
    int id PK
    int order_id FK
    text item_type "pizza or product"
    int product_id FK "nullable. set when item_type = product"
    int product_size_id FK "nullable. set when the product is priced per size"
    int product_option_id FK "nullable. set when the product has a chosen option"
    int pizza_group_id FK "nullable. set when item_type = pizza, or product requires_pizza_flavor"
    int pizza_size_id FK "nullable. set when item_type = pizza"
    int pizza_flavor_id FK "nullable. single flavor for gratin/calzone (requires_pizza_flavor products)"
    int quantity
    int unit_price "price snapshot at order time, integer COP"
    text notes "nullable. e.g. sin cebolla"
    text printed_at "nullable. set once this item's been sent to the kitchen (original ticket or addendum)"
  }
  ORDER_ITEM_FLAVORS {
    int order_item_id PK, FK
    int flavor_id PK, FK
  }

  ORDER_PAYMENTS {
    int id PK
    int order_id FK
    text method "cash, card, or transfer"
    int amount "total charged via this method, integer COP, tip included"
    int tip_amount "default 0. slice of amount that's tip, not sales. 0 to amount"
    text created_at "written once, at completion"
  }

  PRINT_JOBS {
    int id PK
    int order_id FK
    text kind "kitchen_ticket or bill"
    text content "rendered ticket text, or bill HTML"
    text created_at
  }

  CASH_REGISTER_SETTINGS {
    int id PK "always 1, single row"
    int default_opening_cash "seeds a new CASH_FLOW period"
  }
  CASH_FLOW {
    int id PK
    text date "YYYY-MM-DD business day. one row per day, auto-opened when stale"
    int cash_in_register "current available cash for this period"
    int expenses "running total of CASH_EXPENSES for this period"
    text created_at
  }
  CASH_EXPENSES {
    int id PK
    int cash_flow_id FK
    int amount "positive integer COP"
    text justification
    text created_at
  }

  CLOSING_REPORTS {
    int id PK
    text date "YYYY-MM-DD business day this report covers"
    int order_count "COMPLETED orders that day"
    int delivery_sales "total+delivery_fee summed for delivery orders, tips excluded"
    int dine_in_takeaway_sales "total+delivery_fee summed for dine_in/takeaway orders"
    int cash_sales "grouped by ORDER_PAYMENTS.method, each row's amount - tip_amount"
    int card_sales
    int transfer_sales
    int total_sales "delivery_sales + dine_in_takeaway_sales"
    int total_expenses "sum of CASH_FLOW.expenses for the day"
    text content "rendered receipt text, for reprint"
    text created_at "always a manual staff action, never auto-generated"
  }
